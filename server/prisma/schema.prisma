generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// --- 1. IDENTITY & ACCESS MANAGEMENT ---

model User {
  id        String   @id // Clerk User ID (user_...)
  email     String   @unique
  name      String?
  image     String?
  members   Member[]
  createdAt DateTime @default(now())
}

model Organization {
  id         String   @id // Clerk Org ID (org_...)
  name       String
  slug       String   @unique
  domain     String?  @unique
  isPersonal Boolean  @default(false)
  logo       String?
  brandColor String   @default("#2563EB")

  members     Member[]
  projects    Project[]
  subscribers Subscriber[]
  createdAt   DateTime     @default(now())
}

model Member {
  id   String @id @default(cuid())
  role Role   @default(MEMBER)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  orgId        String
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([userId, orgId])
}

enum Role {
  ADMIN
  MEMBER
  VIEWER
}

// --- 2. GITHUB INTEGRATION ---

model Project {
  id            String @id @default(cuid())
  name          String
  repoName      String
  repoOwner     String
  githubRepoId  Int    @unique
  defaultBranch String @default("main")

  orgId        String
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  pullRequests GithubPR[]
  entries      ChangelogEntry[]

  createdAt DateTime @default(now())
}

model GithubPR {
  id       String   @id @default(cuid())
  prNumber Int
  title    String
  body     String?  @db.Text
  author   String
  mergedAt DateTime
  used     Boolean  @default(false)

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  entryLinks ChangelogEntryPR[]

  createdAt DateTime @default(now())

  @@unique([projectId, prNumber])
}

// --- 3. CHANGELOG ---

model ChangelogEntry {
  id          String    @id @default(cuid())
  title       String
  content     String    @db.Text
  version     String?
  tags        Tag[]
  isPublished Boolean   @default(false)
  publishedAt DateTime?
  aiDraft     String?   @db.Text

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  // Which PRs were used — via explicit join table
  sourcePRs ChangelogEntryPR[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Explicit join table: ChangelogEntry <-> GithubPR
model ChangelogEntryPR {
  entryId String
  entry   ChangelogEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)

  prId String
  pr   GithubPR @relation(fields: [prId], references: [id], onDelete: Cascade)

  @@id([entryId, prId])
}

enum Tag {
  FEATURE
  BUG_FIX
  IMPROVEMENT
  SECURITY
  PERFORMANCE
  BREAKING_CHANGE
}

// --- 4. SUBSCRIBERS ---

model Subscriber {
  id               String    @id @default(cuid())
  email            String
  confirmedAt      DateTime?
  unsubscribeToken String    @unique @default(cuid())

  orgId        String
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([email, orgId])
}